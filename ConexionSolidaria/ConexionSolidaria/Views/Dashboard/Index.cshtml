@model ConexionSolidaria.ViewModels.DashboardVM

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3" data-aos="fade-down">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="fa-solid fa-chart-pie me-2 text-primary"></i>Resumen Operativo
            </h2>
            <p class="text-secondary mb-0">Bienvenido al panel de control de <strong>Conexión Solidaria</strong>.</p>
        </div>
        <div class="bg-white px-4 py-2 rounded-pill shadow-sm border border-light">
            <span class="text-secondary small fw-bold text-uppercase" style="letter-spacing: 1px;">
                <i class="fa-solid fa-clock me-1 text-primary"></i>
                Corte: <span class="text-dark">@DateTime.Now.ToString("dd MMM yyyy, HH:mm")</span>
            </span>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-5" data-aos="fade-up">
        <div class="card-body p-4">
            <form method="get" action="@Url.Action("Index", "Dashboard")" class="row g-3 align-items-end">

                <div class="col-12 col-md-3">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Buscar Evento</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </span>
                        <input type="text" class="form-control border-start-0 bg-light rounded-end-3" name="search" placeholder="Nombre o ubicación..." value="@Context.Request.Query["search"]">
                    </div>
                </div>

                <div class="col-12 col-md-2">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Estado</label>
                    <select class="form-select bg-light rounded-3" name="estado">
                        <option value="">Todos</option>
                        <option value="Programado" selected="@(Context.Request.Query["estado"] == "Programado")">Programado</option>
                        <option value="Realizado" selected="@(Context.Request.Query["estado"] == "Realizado")">Realizado</option>
                        <option value="Cancelado" selected="@(Context.Request.Query["estado"] == "Cancelado")">Cancelado</option>
                    </select>
                </div>

                <div class="col-12 col-md-2">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Fecha Desde</label>
                    <input type="date" class="form-control bg-light rounded-3" name="fechaInicio" value="@Context.Request.Query["fechaInicio"]">
                </div>

                <div class="col-12 col-md-2">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Fecha Hasta</label>
                    <input type="date" class="form-control bg-light rounded-3" name="fechaFin" value="@Context.Request.Query["fechaFin"]">
                </div>

                <div class="col-12 col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1 rounded-3 shadow-sm fw-bold">
                        <i class="fa-solid fa-filter me-2"></i>Filtrar
                    </button>
                    <a href="@Url.Action("Index", "Dashboard")" class="btn btn-light rounded-3 shadow-sm px-3" title="Limpiar filtros">
                        <i class="fa-solid fa-rotate-right text-secondary"></i>
                    </a>
                </div>

            </form>
        </div>
    </div>

    <div class="row g-4 mb-5" data-aos="fade-up" data-aos-delay="100">

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-elevate">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 me-3">
                        <i class="fa-solid fa-calendar-check fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Eventos Listados</h6>
                        <h2 class="fw-black text-dark mb-0">@Model.Eventos.Count</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-elevate">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 me-3">
                        <i class="fa-solid fa-users fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Inscripciones</h6>
                        <h2 class="fw-black text-dark mb-0">@Model.Inscripciones.Count</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-elevate">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3 me-3">
                        <i class="fa-solid fa-door-open fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Cupos Libres</h6>
                        <h2 class="fw-black text-dark mb-0">@Model.Eventos.Sum(e => e.CupoDisponible)</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 hover-elevate">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 text-info rounded-circle p-3 me-3">
                        <i class="fa-solid fa-bolt fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Activos</h6>
                        <h2 class="fw-black text-dark mb-0">@Model.Eventos.Count(e => e.EstadoEvento == "Programado")</h2>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4">

        <div class="col-lg-7" data-aos="fade-right">
            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h5 class="fw-bold text-dark mb-0">
                        <i class="fa-solid fa-list-check text-primary me-2"></i>
                        Lista de Eventos
                    </h5>
                </div>

                <div class="card-body px-4 py-3">
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle table-custom-hover mb-0">
                            <thead class="text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-0 fw-bold">Evento</th>
                                    <th class="text-center fw-bold">Ocupación</th>
                                    <th class="text-end pe-0 fw-bold">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Eventos.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted">
                                            No se encontraron eventos con estos filtros.
                                        </td>
                                    </tr>
                                }
                                @foreach (var e in Model.Eventos)
                                {
                                    <tr class="border-bottom">
                                        <td class="ps-0 py-3">
                                            <div class="fw-bold text-dark">@e.Nombre</div>
                                            <div class="text-muted small">
                                                <i class="fa-solid fa-calendar me-1 text-primary"></i>
                                                @e.Fecha.ToString("dd MMM yyyy")
                                            </div>
                                            <div class="text-muted small">
                                                <i class="fa-solid fa-clock me-1 text-secondary"></i>
                                                @e.HoraInicio.ToString(@"hh\:mm") - @e.HoraFin.ToString(@"hh\:mm")
                                            </div>
                                            <div class="text-muted small">
                                                <i class="fa-solid fa-location-dot text-danger me-1"></i>
                                                @e.Lugar
                                            </div>
                                        </td>
                                        <td class="text-center py-3">
                                            <div class="d-flex justify-content-between small mb-1">
                                                <span class="fw-bold text-dark">@e.TotalInscritos</span>
                                                <span class="text-muted">/ @e.CupoMaximo</span>
                                            </div>
                                            <div class="progress rounded-pill" style="height:6px;">
                                                @{
                                                    var porcentaje = (e.TotalInscritos * 100) / (e.CupoMaximo > 0 ? e.CupoMaximo : 1);
                                                    var colorBarra = porcentaje >= 90 ? "bg-danger" : porcentaje >= 60 ? "bg-warning" : "bg-success";
                                                }
                                                <div class="progress-bar progress-bar-striped progress-bar-animated @colorBarra"
                                                     style="width:@porcentaje%">
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            @{
                                                var badgeBg =
                                                e.EstadoEvento == "Programado" ? "bg-info bg-opacity-10 text-info" :
                                                e.EstadoEvento == "Realizado" ? "bg-success bg-opacity-10 text-success" :
                                                "bg-danger bg-opacity-10 text-danger";
                                            }
                                            <span class="badge rounded-pill @badgeBg px-3 py-2">
                                                @e.EstadoEvento
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-lg-5" data-aos="fade-left">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold text-dark mb-0">
                            <i class="fa-solid fa-user-clock text-success me-2"></i>
                            Voluntarios
                        </h5>
                        <span class="badge bg-secondary rounded-pill">@Model.Inscripciones.Count</span>
                    </div>
                </div>

                <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">

                    <ul class="list-group list-group-flush">
                        @if (!Model.Inscripciones.Any())
                        {
                            <li class="list-group-item border-0 py-4 text-center text-muted">
                                No hay personas inscritas para la selección actual.
                            </li>
                        }

                        @foreach (var i in Model.Inscripciones)
                        {
                            <li class="list-group-item border-0 py-3 px-4 border-bottom">

                                <div class="d-flex align-items-center">

                                    <div class="avatar-circle bg-light text-primary rounded-circle me-3 shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                        @(string.IsNullOrEmpty(i.NombreVoluntario) ? "?" : i.NombreVoluntario.Substring(0, 1).ToUpper())
                                    </div>

                                    <div class="flex-grow-1">
                                        <div class="fw-bold text-dark">@i.NombreVoluntario</div>
                                        <div class="text-muted small">
                                            <i class="fa-solid fa-ticket me-1"></i>
                                            @i.Evento
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <span class="badge bg-light text-secondary rounded-pill shadow-sm">
                                            @i.FechaInscripcion.ToString("dd MMM")
                                        </span>
                                    </div>

                                </div>

                            </li>
                        }
                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>