@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Inicio";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<section class="py-5 bg-gradient-hero overflow-hidden border-bottom">
    <div class="container-fluid full-width-container">
        <div class="row align-items-center min-vh-80">

            <div class="col-lg-7" data-aos="fade-right" data-aos-duration="1000">
                <h1 class="display-3 fw-bold text-primary mb-4">
                    Conectando personas<br />con causas que importan
                </h1>

                <p class="fs-4 text-muted mb-5" style="max-width: 800px;">
                    <strong>Conexion Solidaria</strong> impulsa el voluntariado y la
                    organización de eventos sociales, conectando personas comprometidas
                    con iniciativas que generan impacto real en la comunidad.
                </p>
            </div>

            <div class="col-lg-5 text-center d-none d-lg-block" data-aos="zoom-in" data-aos-delay="300">
                <div class="position-relative">
                    <i class="bi bi-people-fill text-primary" style="font-size: 350px; opacity: 0.05;"></i>
                    <div class="position-absolute top-50 start-50 translate-middle">
                        <i class="bi bi-heart-pulse-fill text-primary" style="font-size: 120px;"></i>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container-fluid full-width-container">
        <div class="row text-center g-4 justify-content-between">
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="100">
                <div class="p-3">
                    <h2 class="fw-bold text-primary display-4">+100</h2>
                    <p class="text-muted text-uppercase fw-semibold ls-1">Voluntarios Activos</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="200">
                <div class="p-3">
                    <h2 class="fw-bold text-primary display-4">+40</h2>
                    <p class="text-muted text-uppercase fw-semibold ls-1">Eventos Realizados</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="300">
                <div class="p-3">
                    <h2 class="fw-bold text-primary display-4">+1,200</h2>
                    <p class="text-muted text-uppercase fw-semibold ls-1">Horas Donadas</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="400">
                <div class="p-3">
                    <h2 class="fw-bold text-primary display-4">100%</h2>
                    <p class="text-muted text-uppercase fw-semibold ls-1">Gestión Digital</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container-fluid full-width-container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="fw-bold display-5">¿Cómo funciona?</h2>
            <p class="text-muted fs-5">Únete a la red en tres simples pasos</p>
            <hr class="mx-auto bg-primary opacity-100" style="width: 60px; height: 3px;">
        </div>

        <div class="row g-4">
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100 shadow-sm border-0 hover-card p-4 text-center">
                    <div class="card-body">
                        <div class="icon-box">
                            <i class="bi bi-person-plus-fill fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3">1. Regístrate</h4>
                        <p class="text-muted">
                            Crea tu perfil en segundos y accede a todas las oportunidades de voluntariado disponibles.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card h-100 shadow-sm border-0 hover-card p-4 text-center">
                    <div class="card-body">
                        <div class="icon-box">
                            <i class="bi bi-calendar-check-fill fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3">2. Inscríbete</h4>
                        <p class="text-muted">
                            Filtra por tus intereses y selecciona el evento que mejor se adapte a tu tiempo.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card h-100 shadow-sm border-0 hover-card p-4 text-center">
                    <div class="card-body">
                        <div class="icon-box">
                            <i class="bi bi-heart-fill fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3">3. Genera Impacto</h4>
                        <p class="text-muted">
                            Participa activamente y ayuda a transformar la realidad de tu comunidad local.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-primary text-white position-relative overflow-hidden">
    <div class="position-absolute top-0 end-0 p-5 opacity-10">
        <i class="bi bi-globe-americas" style="font-size: 200px;"></i>
    </div>

    <div class="container text-center py-4 position-relative" data-aos="zoom-in">
        <h2 class="fw-bold mb-3 display-4">Sé parte del cambio</h2>
        <p class="fs-4 mb-4 opacity-75">
            Tu tiempo y tu esfuerzo son el motor de grandes transformaciones.
        </p>
        <button type="button"
                class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary shadow"
                data-bs-toggle="modal"
                data-bs-target="#loginModal">
            EMPEZAR AHORA
        </button>
    </div>
</section>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}
