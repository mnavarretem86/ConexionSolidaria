@model List<ConexionSolidaria.ViewModels.MisInscripcionesVM>

@{
    ViewData["Title"] = "Mis Inscripciones";
}
<div class="container-fluid eventos-container">
    <h2 class="text-dark fw-bold mb-4">
        <i class="fas fa-clipboard-check text-primary me-2"></i>Mis Inscripciones
    </h2>

    @if (Model.Count == 0)
    {
        <div class="card shadow-sm border-0 text-center p-5">
            <div class="card-body">
                <i class="fas fa-calendar-minus fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">No estás inscrito en ningún 
                    ctualmente.</h4>
                <a asp-controller="Eventos" asp-action="Index" class="btn btn-primary mt-3 btn-hover">
                    <i class="fas fa-search me-1"></i> Explorar Eventos
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card table-eventos-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-modern table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Evento</th>
                                <th>Fecha y Lugar</th>
                                <th>Fecha Registro</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="text-event-title">@item.NombreEvento</span>
                                        <small class="text-muted">Ref: #@item.EventoID</small>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column small">
                                            <span class="fw-bold"><i class="far fa-calendar text-primary me-1"></i>@item.Fecha.ToString("dd/MM/yyyy")</span>
                                            <span class="text-muted"><i class="fas fa-location-dot me-1"></i>@item.Lugar</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="small text-muted text-nowrap">
                                            <i class="far fa-clock me-1"></i>@item.FechaInscripcion.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (item.EstadoID == 4)
                                        {
                                            <form asp-controller="Inscripciones" asp-action="Desinscribirse" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="eventoId" value="@item.EventoID" />
                                                <button type="button" class="btn btn-sm btn-outline-danger btn-hover btn-confirmar-des">
                                                    <i class="fas fa-times-circle me-1"></i> Cancelar Inscripción
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            @if (item.EstadoID == 5)
                                            {
                                                <span class="badge badge-soft-info"><i class="fas fa-check me-1"></i>Asistido</span>
                                            }
                                            else
                                            {

                                                <span class="text-muted small italic">Finalizado</span>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        window.mensajeExito = '@TempData["Exito"]';
        window.mensajeError = '@TempData["Error"]';
    </script>
    <script src="~/js/inscripciones.js" asp-append-version="true"></script>
}