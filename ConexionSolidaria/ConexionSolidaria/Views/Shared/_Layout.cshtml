@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ConexionSolidaria</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />


    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <!-- Estilos -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/ConexionSolidaria.styles.css" />
</head>

<body class="bg-light">

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">

                <!-- Logo -->
                <a class="navbar-brand fw-bold text-primary"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <i class="bi bi-heart-pulse-fill me-1"></i> ConexionSolidaria
                </a>

                <!-- Toggle -->
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menú -->
                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- Menú izquierdo -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Dashboard"
                               asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Eventos"
                               asp-action="Index">
                                <i class="bi bi-calendar-event me-1"></i> Eventos
                            </a>
                        </li>

                        @if (Context.Session.GetString("Rol") == "Coordinador")
                        {
                            <!-- IAM SOLO COMO MENÚ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">
                                    <i class="bi bi-shield-lock me-1"></i> IAM
                                </a>

                                <ul class="dropdown-menu shadow-sm">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Persona"
                                           asp-action="Index">
                                            <i class="bi bi-people me-2"></i> Personas
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Usuario"
                                           asp-action="Index">
                                            <i class="bi bi-person-badge me-2"></i> Usuarios
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <!-- Zona derecha -->
                    <ul class="navbar-nav">

                        @if (Context.Session.GetInt32("UsuarioID") == null)
                        {
                            <!-- LOGIN -->
                            <li class="nav-item">
                                <button class="btn btn-outline-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#loginModal">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </button>
                            </li>
                        }
                        else
                        {
                            <!-- USUARIO LOGUEADO -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-semibold"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @Context.Session.GetString("Nombre")
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                    <li class="dropdown-header text-muted">
                                        Rol: @Context.Session.GetString("Rol")
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Auth"
                                              asp-action="Logout"
                                              method="post">
                                            <button class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-1"></i>
                                                Cerrar sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENIDO -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="border-top text-center text-muted py-3 small">
        &copy; 2025 - ConexionSolidaria
    </footer>

    <!-- MODAL LOGIN -->
    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-lock me-1"></i> Iniciar Sesión
                    </h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div id="loginMessage" class="alert d-none"></div>

                    <form id="loginForm">

                        <div class="mb-3">
                            <label class="form-label">Correo</label>
                            <input type="email"
                                   id="loginEmail"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <div class="input-group">
                                <input type="password"
                                       id="loginPassword"
                                       class="form-control"
                                       required />
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        onclick="togglePassword()">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100">
                            <i class="bi bi-box-arrow-in-right me-1"></i>
                            Ingresar
                        </button>

                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/js/auth.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: "toast-top-right",
            timeOut: "3000"
        };
    </script>



    <script>
        function togglePassword() {
            const input = document.getElementById("loginPassword");
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
