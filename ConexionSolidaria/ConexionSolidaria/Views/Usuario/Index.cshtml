@model List<ConexionSolidaria.Models.UsuarioViewModel>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark m-0">
        <i class="fa-solid fa-user-shield text-primary me-2"></i>Gestión de Usuarios
    </h3>

    <button class="btn btn-primary px-4 shadow-sm"
            data-bs-toggle="modal"
            data-bs-target="#modalCrear">
        <i class="fa-solid fa-user-plus me-2"></i>Nuevo Usuario
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 ps-3">Persona</th>
                        <th class="border-0">Acceso (Email)</th>
                        <th class="border-0">Rol asignado</th>
                        <th class="border-0">Estado</th>
                        <th class="border-0 text-center pe-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-medium">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-2 text-center" style="width: 35px; height: 35px;">
                                        <i class="fa-solid fa-user small"></i>
                                    </div>
                                    @u.NombreCompleto
                                </div>
                            </td>
                            <td>
                                <span class="text-muted small">
                                    <i class="fa-solid fa-envelope me-1"></i> @u.Email
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3">
                                    @u.NombreRol
                                </span>
                            </td>
                            <td>
                                @if (u.EstadoID == 1)
                                {
                                    <span class="badge rounded-pill bg-success px-3">
                                        <i class="fa-solid fa-check-circle me-1"></i> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger px-3">
                                        <i class="fa-solid fa-ban me-1"></i> Inactivo
                                    </span>
                                }
                            </td>
                            <td class="text-center pe-3">
                                <button type="button"
                                        class="btn btn-sm btn-light border"
                                        onclick="abrirEditar(this)"
                                        data-usuarioid="@u.UsuarioID"
                                        data-rolid="@u.RolID">
                                    <i class="fa-solid fa-user-gear text-warning"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form id="formCrear">
                <div class="modal-header bg-primary text-white py-3">
                    <h5 class="modal-title fw-bold">
                        <i class="fa-solid fa-circle-plus me-2"></i>Crear Cuenta de Usuario
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="alert alert-primary d-flex align-items-center border-0 bg-opacity-10 mb-4" role="alert">
                        <i class="fa-solid fa-circle-info me-2 text-primary"></i>
                        <div class="small text-primary">
                            Solo se muestran personas que <strong>no tienen credenciales</strong> de acceso actualmente.
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Seleccionar Persona</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user-tag text-muted"></i></span>
                                <select class="form-select bg-light border-start-0" name="PersonaID" id="crearPersona" required>
                                    <option value="">Cargando personas...</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Rol de Usuario</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-id-badge text-muted"></i></span>
                                <select class="form-select bg-light border-start-0" name="RolID" id="crearRol" required>
                                    <option value="">Seleccione un rol</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Contraseña Temporal</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                                <input type="password" class="form-control bg-light border-start-0" name="Contrasena" placeholder="********" required />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Habilitar Acceso
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form id="formEditar">
                <input type="hidden" name="UsuarioID" />
                <div class="modal-header bg-dark text-white py-3">
                    <h5 class="modal-title fw-bold">
                        <i class="fa-solid fa-user-pen me-2"></i>Modificar Credenciales
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4 text-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="fa-solid fa-shield-halved fa-2x"></i>
                    </div>
                    <p class="text-muted small mb-4">Actualice el rol o restablezca la contraseña del usuario seleccionado.</p>

                    <div class="row g-3 text-start">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Cambiar Rol</label>
                            <select class="form-select bg-light" name="RolID" id="editarRol" required></select>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Nueva Contraseña</label>
                            <input type="password" class="form-control" name="Contrasena" placeholder="Dejar vacío para no cambiar" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="fa-solid fa-arrows-rotate me-2"></i>Actualizar Usuario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/usuario.js"></script>
}